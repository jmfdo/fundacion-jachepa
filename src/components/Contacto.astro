  </div>
</section>

<style>
  .contacto {
    padding: 6rem 2rem;
    background: var(--color-primario);
    position: relative;
    overflow: hidden;
  }

  /* Orbe decorativo de fondo */
  .contacto::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
    top: -200px;
    right: -150px;
    pointer-events: none;
  }

  .contacto::after {
    content: '';
    position: absolute;
    width: 400px;
    height: 400px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
    bottom: -150px;
    left: -100px;
    pointer-events: none;
  }

  .contacto__inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Encabezado */
  .contacto__encabezado {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 560px;
  }

  .contacto__tag {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
    padding: 0.35rem 1rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    width: fit-content;
    border: 1px solid rgba(255,255,255,0.2);
  }

  .contacto__titulo {
    font-family: var(--fuente-titulo);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: #ffffff;
    line-height: 1.15;
  }

  .contacto__titulo em {
    font-style: italic;
    color: rgba(255,255,255,0.65);
  }

  .contacto__subtitulo {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
  }

  .contacto__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .contacto__item--email {
    grid-column: 2 / 3;
  }

  .contacto__item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1.1rem 1.5rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radio);
    color: #ffffff;
    text-decoration: none;
    transition: background 0.25s, transform 0.2s, border-color 0.25s;
    backdrop-filter: blur(8px);
  }

  .contacto__item:hover {
    background: rgba(255,255,255,0.18);
    border-color: rgba(255,255,255,0.3);
    transform: translateY(-3px);
  }

  .contacto__icono {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contacto__icono svg {
    width: 24px;
    height: 24px;
  }

  /* Colores de cada red */
  .contacto__item--instagram .contacto__icono { color: #E1306C; }
  .contacto__item--facebook  .contacto__icono { color: #1877F2; }
  .contacto__item--tiktok    .contacto__icono { color: #ffffff; }
  .contacto__item--whatsapp  .contacto__icono { color: #25D366; }
  .contacto__item--email     .contacto__icono { color: rgba(255,255,255,0.8); }

  .contacto__label {
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(255,255,255,0.9);
    white-space: nowrap;
  }

 @media (max-width: 768px) {
    .contacto__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .contacto__item--email {
      grid-column: span 2;
    }
  }

  @media (max-width: 480px) {
    .contacto__grid {
      grid-template-columns: 1fr;
    }

    .contacto__item--email {
      grid-column: span 1;
    }
  }
</style>