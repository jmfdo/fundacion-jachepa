---
const contactos = [
  {
    icono: "instagram",
    label: "@jachepafundacion",
    href: "https://instagram.com/jachepafundacion",
  },
  {
    icono: "facebook",
    label: "Fundación Jachepa",
    href: "https://www.facebook.com/profile.php?id=61576404291836&mibextid=wwXIfr&rdid=YSOmmdiH1ygZN4i7&share_url=https%3A%2F%2Fwww.facebook.com%2Fshare%2F1BMUHRfNju%2F%3Fmibextid%3DwwXIfr",
  },
  {
    icono: "tiktok",
    label: "@jachepafundacion",
    href: "https://www.tiktok.com/@fundacion.jachepa?_r=1&_t=ZS-94yNtDJt3f3",
  },
  {
    icono: "whatsapp",
    label: "+57 324 5884759",
    href: "https://wa.me/573245884759",
  },
  {
    icono: "email",
    label: "jachepafundacion@gmail.com",
    href: "mailto:jachepafundacion@gmail.com",
  },
];
---

<section class="contacto" id="contacto">
  <div class="contacto__inner">

    <div class="contacto__encabezado">
      <span class="contacto__tag">Contáctanos</span>
      <h2 class="contacto__titulo">¿Quieres ser parte del <em>cambio</em>?</h2>
      <p class="contacto__subtitulo">Escríbenos o síguenos en nuestras redes. Juntos podemos hacer más.</p>
    </div>

    <div class="contacto__grid">
      {contactos.map(c => (
        <a href={c.href} target="_blank" rel="noopener noreferrer" class={`contacto__item contacto__item--${c.icono}`}>
          <span class="contacto__icono">
            {c.icono === "instagram" && (
