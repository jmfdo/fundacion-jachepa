---
const { title, description, ogImage = "./og-image.jpg" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="fundación, jachepa, ONG, colombia, maicao, ayuda social, comunidades vulnerables, bienestar animal, niñez, educación, accion comunitaria, desarrollo sostenible"
    />
    <meta name="author" content="Fundación Jachepa" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content={`https://fundacionjachepa.netlify.app${Astro.url.pathname}`}
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://fundacionjachepa.netlify.app/og-image.jpeg" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="Fundación Jachepa" />  

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://fundacionjachepa.netlify.app/og-image.jpeg" />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-primario: #3e2eac; /* morado Jachepa */
    --color-primario-oscuro: #2e2080; /* morado más oscuro para hovers */
    --color-primario-claro: #6557c8; /* morado más claro para acentos */
    --color-primario-suave: #eeecf9; /* fondo suave derivado del morado */
    --color-blanco: #ffffff;
    --color-fondo: #f7f6fd; /* blanco con tinte morado muy sutil */
    --color-texto: #1a1535; /* casi negro con tinte morado */
    --color-texto-suave: #5a5475; /* gris morado para textos secundarios */
    --color-borde: #ddd9f5;

    --fuente-titulo: "Playfair Display", Georgia, serif;
    --fuente-cuerpo: "DM Sans", sans-serif;

    --radio: 12px;
    --sombra: 0 4px 24px rgba(62, 46, 172, 0.12);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--fuente-cuerpo);
    background-color: var(--color-fondo);
    color: var(--color-texto);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: var(--fuente-titulo);
    line-height: 1.2;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }
</style>
