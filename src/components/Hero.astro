---
import { Image } from "astro:assets";
import heroBg from '../assets/images/hero.jpeg';
---

<section class="hero">
  <div class="hero__bg">
    <Image
      src={heroBg}
      alt="Fundación Jachepa trabajando con la comunidad"
      class="hero__bg-img"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__inner">
    <div class="hero__contenido">
      
      <h1 class="hero__titulo">
        Construyendo un futuro <em>más digno</em> para todos
      </h1>
      <p class="hero__descripcion">
        Somos la Fundación Jachepa, una organización dedicada al desarrollo social, educativo, cultural y humanitario de las comunidades más vulnerables. Creemos en la solidaridad, la inclusión y el poder del trabajo colectivo.
      </p>
      <div class="hero__acciones">
        <a href="#contacto" class="btn btn--primario">Súmate ahora</a>
        <a href="#proyectos" class="btn btn--secundario">Ver proyectos</a>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding: 50px 2rem 80px;
    margin-top: 70px; /* para compensar la altura del navbar fijo */
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(22, 20, 65, 0.8) 0%, rgba(0, 0, 0, 0.4) 100%);
  }

  /* Contenido */
  .hero__inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .hero__contenido {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    animation: aparecerAbajo 0.8s ease forwards;
  }

  @keyframes aparecerAbajo {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero__titulo {
    font-family: var(--fuente-titulo);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    color: #ffffff;
    line-height: 1.1;
  }

  .hero__titulo em {
    font-style: italic;
    color: rgba(255, 255, 255, 0.75);
  }

  .hero__descripcion {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.75);
    max-width: 580px;
    line-height: 1.7;
  }

  /* Botones */
  .hero__acciones {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.85rem 2rem;
    border-radius: var(--radio);
    font-size: 1rem;
    font-weight: 600;
    transition: transform 0.2s, background 0.2s, box-shadow 0.2s;
    cursor: pointer;
  }

  .btn--primario {
    background: #ffffff;
    color: var(--color-primario);
  }

  .btn--primario:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }

  .btn--secundario {
    background: rgba(255,255,255,0.12);
    color: #FFFFFF;
    border: 1px solid rgba(255,255,255,0.3);
    backdrop-filter: blur(8px);
  }

  .btn--secundario:hover {
    background: rgba(255,255,255,0.2);
    transform: translateY(-2px);
  }

  


  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 50px 1.5rem 60px;
    }

    .hero__titulo {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .hero__acciones {
      flex-direction: column;
    }

    .btn {
      text-align: center;
    }
  }
</style>