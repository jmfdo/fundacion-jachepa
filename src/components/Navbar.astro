---
const links = [
  { href: "#nosotros",    label: "Nosotros" },
  { href: "#proyectos", label: "Proyectos" },
  { href: "#galeria",    label: "Galería" },
  { href: "#contacto",  label: "Contacto" },
];
---

<header class="navbar">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo">
      <img src="/isotipo.svg" alt="Fundación Jachepa" class="navbar__logo-img" />
      <span class="navbar__logo-nombre">Fundación <strong>Jachepa</strong></span>
    </a>

    <nav class="navbar__links">
      {links.map(link => (
        <a href={link.href} class="navbar__link">{link.label}</a>
      ))}
    </nav>

    <!-- <a class="navbar__cta">Donar ahora</a> -->

    <button class="navbar__burger" id="burger" aria-label="Abrir menú">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <nav class="navbar__mobile" id="mobile-menu">
    {links.map(link => (
      <a href={link.href} class="navbar__mobile-link">{link.label}</a>
    ))}
    <!-- <a class="navbar__cta navbar__cta--mobile">Donar ahora</a> -->
  </nav>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(62, 46, 172, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .navbar__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }

  .navbar__logo-img {
    height: 45px;
    width: auto;
    filter: brightness(1);
  }

  .navbar__logo-nombre {
    font-family: var(--fuente-cuerpo);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.01em;
  }

  .navbar__logo-nombre strong {
    color: #ffffff;
    font-weight: 700;
  }

  /* Links desktop */
  .navbar__links {
    display: flex;
    gap: 1.75rem;
    align-items: center;
  }

  .navbar__link {
    font-size: 0.92rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    transition: color 0.2s;
    position: relative;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: rgba(255, 255, 255, 0.9);
    transition: width 0.25s ease;
  }

  .navbar__link:hover {
    color: #ffffff;
  }

  .navbar__link:hover::after {
    width: 100%;
  }

  /* CTA */
  .navbar__cta {
    background: rgba(255, 255, 255, 0.15);
    color: #ffffff;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radio);
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: background 0.2s, transform 0.1s;
  }

  .navbar__cta:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: translateY(-1px);
  }

  /* Hamburguesa */
  .navbar__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .navbar__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #ffffff;
    border-radius: 2px;
    transition: all 0.3s;
  }

  /* Menú mobile */
  /* .navbar__mobile {
    display: none;
    flex-direction: column;
    padding: 1rem 2rem 1.5rem;
    gap: 0.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(62, 46, 172, 0.95);
  } */

  .navbar__mobile {
    display: none;
    flex-direction: column;
    padding: 1rem 2rem 1rem;
    gap: 0.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(62, 46, 172, 0.95);
  }

  .navbar__mobile-link:last-child {
    border-bottom: none;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .navbar__mobile.is-open {
    display: flex;
    animation: slideDown 0.25s ease forwards;
  }

  .navbar__mobile-link {
    padding: 0.65rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    transition: color 0.2s;
  }

  .navbar__mobile-link:hover {
    color: #ffffff;
  }

  .navbar__cta--mobile {
    margin-top: 1rem;
    text-align: center;
    padding: 0.75rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .navbar__links { display: none; }
    .navbar__cta:not(.navbar__cta--mobile) { display: none; }
    .navbar__burger { display: flex; }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-menu');

  burger?.addEventListener('click', () => {
    menu?.classList.toggle('is-open');
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) {
      menu?.classList.remove('is-open');
    }
  });
</script>