<style>
  .nosotros {
    padding: 6rem 2rem;
    background: var(--color-blanco);
  }

  .nosotros__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  /* Encabezado */
  .nosotros__encabezado {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 620px;
  }

  .nosotros__tag {
    display: inline-block;
    background: var(--color-primario-suave);
    color: var(--color-primario);
    padding: 0.35rem 1rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    width: fit-content;
  }

  .nosotros__titulo {
    font-family: var(--fuente-titulo);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: var(--color-texto);
    line-height: 1.15;
  }

  .nosotros__titulo em {
    font-style: italic;
    color: var(--color-primario);
  }

  /* Cards misión / visión */
  .nosotros__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .nosotros__card {
    background: var(--color-fondo);
    border: 1px solid var(--color-borde);
    border-radius: var(--radio);
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.25s, transform 0.25s;
  }

  .nosotros__card:hover {
    box-shadow: var(--sombra);
    transform: translateY(-4px);
  }

  .nosotros__icono {
    width: 48px;
    height: 48px;
    background: var(--color-primario-suave);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primario);
    flex-shrink: 0;
  }

  .nosotros__icono svg {
    width: 24px;
    height: 24px;
  }

  .nosotros__card-titulo {
    font-family: var(--fuente-titulo);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-texto);
  }

  .nosotros__card-texto {
    font-size: 0.97rem;
    color: var(--color-texto-suave);
    line-height: 1.75;
  }

  /* Valores */
