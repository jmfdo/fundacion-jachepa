  /* Responsive */
  @media (max-width: 768px) {
    .nosotros__grid {
      grid-template-columns: 1fr;
    }

    .nosotros__valores-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 480px) {
    .nosotros__valores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>